{
  "_meta": {
    "version": "1.0",
    "updated": "2026-06-17",
    "description": "内容审核检查规则注册表。设计文档 v3.2 第三章。",
    "constraint": "severity=blocking 必须 deterministic=true；deterministic=false 的规则 severity 只能是 warning。注册时校验该约束。"
  },

  "rules": [
    {
      "id": "IMG-BRAND-001",
      "category": "品牌一致性",
      "applies_to": ["图片"],
      "severity": "blocking",
      "deterministic": true,
      "description": "检查海报中是否包含社区Logo（模板图层元数据校验）",
      "check_function": "check_logo_presence",
      "enabled": true,
      "added": "2026-06-17",
      "added_by": "设计师"
    },
    {
      "id": "IMG-BRAND-002",
      "category": "品牌一致性",
      "applies_to": ["图片"],
      "severity": "blocking",
      "deterministic": true,
      "description": "是否使用正确的稿定模板ID（校验渲染调用的 template_id 在注册清单内）",
      "check_function": "check_template_id_valid",
      "enabled": true,
      "added": "2026-06-17",
      "added_by": "工具封装者"
    },
    {
      "id": "IMG-BRAND-003",
      "category": "品牌一致性",
      "applies_to": ["图片"],
      "severity": "warning",
      "deterministic": false,
