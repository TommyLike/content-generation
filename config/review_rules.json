      "check_function": "check_color_palette",
      "enabled": true,
      "added": "2026-06-17",
      "added_by": "设计师"
    },
    {
      "id": "IMG-TEXT-001",
      "category": "文字准确性",
      "applies_to": ["图片"],
      "severity": "warning",
