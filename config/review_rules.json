      "check_function": "check_date_format",
      "enabled": true,
      "added": "2026-06-17",
      "added_by": "工具封装者"
    },
    {
      "id": "IMG-TEXT-003",
      "category": "文字准确性",
      "applies_to": ["图片"],
      "severity": "blocking",
      "deterministic": true,
