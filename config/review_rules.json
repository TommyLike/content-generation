      "check_function": "check_date_match",
      "enabled": true,
      "added": "2026-06-17",
      "added_by": "工具封装者"
    },
    {
      "id": "IMG-TEXT-004",
      "category": "文字准确性",
      "applies_to": ["图片"],
      "severity": "warning",
