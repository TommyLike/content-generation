# =============================================================================
# 环境变量模板 — 复制为 .env 后填入真实值
# .env 不入 git（已在 .gitignore）
# =============================================================================

# --- 域名与入口 ---
N8N_HOST=your-domain.com
WEBHOOK_URL=https://your-domain.com/

# --- 数据库 ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=<生成强密码>
POSTGRES_DB=n8n

# --- n8n 安全 ---
# 生成: openssl rand -hex 32
N8N_ENCRYPTION_KEY=<生成并妥善备份>
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<生成强密码>

# --- n8n 执行模式 ---
# Phase 0: regular（单进程即可）
# 生产: queue（高并发 + Redis）
N8N_EXECUTIONS_MODE=regular

# --- 日志 ---
N8N_LOG_LEVEL=info
EXECUTIONS_DATA_MAX_AGE=336

# --- 飞书 ---
FEISHU_APP_ID=<飞书自建应用 App ID>
FEISHU_APP_SECRET=<飞书自建应用 App Secret>
FEISHU_BITABLE_APP_TOKEN=<多维表格 App Token>
FEISHU_TABLE_ID=<数据表 Table ID>
FEISHU_VERIFICATION_TOKEN=<事件订阅 Verification Token>
FEISHU_ENCRYPT_KEY=<事件订阅 Encrypt Key>

# --- 内部 Webhook 鉴权 ---
INTERNAL_WEBHOOK_TOKEN=<生成随机 token，所有子工作流统一校验>

# --- 稿定开放平台 ---
GAODING_API_KEY=<稿定 API Key>
GAODING_API_SECRET=<稿定 API Secret>
GAODING_TEMPLATE_EVENT_PREVIEW=<活动预告模板 ID>
GAODING_TEMPLATE_EVENT_REVIEW=<活动回顾模板 ID>
GAODING_TEMPLATE_GUEST_POSTER=<嘉宾海报模板 ID>

# --- AI 图像 API（通义万相）---
TONGYI_WANXIANG_API_KEY=<通义万相 API Key>

# --- Dify ---
DIFY_API_URL=http://dify-api:5001
DIFY_API_KEY_ARTICLE_RECRUIT=<活动招募推文 workflow key>
DIFY_API_KEY_ARTICLE_REVIEW=<活动回顾推文 workflow key>

# --- 云内容安全 API（阿里云/腾讯云）---
CONTENT_SECURITY_API_KEY=<内容安全 API Key>
CONTENT_SECURITY_API_SECRET=<内容安全 API Secret>

# --- 即梦/可灵（视频，可选）---
JIMENG_API_KEY=<即梦 API Key>
JIMENG_API_SECRET=<即梦 API Secret>
